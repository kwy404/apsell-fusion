    "amqplib": "^0.10.4",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.21",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/amqplib": "^0.10.5",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
